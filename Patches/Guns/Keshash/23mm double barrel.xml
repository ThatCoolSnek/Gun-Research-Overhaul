<?xml version="1.0" encoding="utf-8" ?>

<Patch>

    <Operation Class="PatchOperationFindMod">
		<mods>
			<li>Gun Variety - 23mm double barrel</li>
		</mods>
        <match Class="PatchOperationSequence">
        <operations>
            <!-- Toz-34-23 -->
            <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="Kesh_Gun_TOZChimera"]/recipeMaker/researchPrerequisite</xpath>
                    <value>
                        <researchPrerequisite Inherit="False">Snek_BreakAction</researchPrerequisite>
                    </value>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>Defs/ThingDef[defName="Kesh_Gun_TOZChimera"]/recipeMaker</xpath>
                    <value>
                        <researchPrerequisites>
                            <li>Snek_Highcaliber</li>
                        </researchPrerequisites>
                    </value>
            </li>
        </operations>
    </match>
</Operation>

</Patch>